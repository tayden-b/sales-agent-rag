# ===========================================
# Sales Call Intelligence System - Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM (Required) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Email (Required for sending; optional if using preview mode) ---
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_TO=you@yourdomain.com

# --- Optional Settings ---
# Print email to console instead of sending (default: true)
EMAIL_PREVIEW_MODE=true

# ChromaDB storage path (default: ./chroma_db)
CHROMA_DB_PATH=./chroma_db

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
